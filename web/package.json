{
  "name": "nokin-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Nokin lens explorer — Vite + React SPA plus Cloudflare Pages Functions for eBay market data.",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k -n VITE,PAGES -c cyan,magenta \"vite\" \"wrangler pages dev --proxy 5173 --port 8788\"",
    "build": "tsc -b && vite build",
    "preview": "wrangler pages dev ./dist --port 8788",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
